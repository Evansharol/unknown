Design and develop an Android application using Apache Cordova to:
Find and display current location
Show nearby:
Hospitals
ATMs
Restaurants
Use public Places API (like OpenStreetMap / Foursquare)
COMMAND

npm install -g cordova
cordova create hello com.example.hello myapp
Add plugin:
cordova plugin add cordova-plugin-geolocation
Code:
<!DOCTYPE html>
<html>
<head>
  <title>Location App</title>
</head>
<body align="center">


<h2>My Location App</h2>


<button onclick="getLoc()">Get Location</button>


<p id="loc"></p>
<p id="res"></p>


<script>


function getLoc(){
  navigator.geolocation.getCurrentPosition(show);
}


function show(p){
  let lat = p.coords.latitude;
  let lon = p.coords.longitude;


  document.getElementById("loc").innerHTML =
    "Lat: " + lat + "<br>Lon: " + lon;


  find(lat, lon);
}


function find(lat, lon){


  let q = `
  [out:json];
  (
    node["amenity"="hospital"](around:1000, ${lat}, ${lon});
    node["amenity"="atm"](around:1000, ${lat}, ${lon});
    node["amenity"="restaurant"](around:1000, ${lat}, ${lon});
  );
  out;
  `;


  let url = "https://overpass-api.de/api/interpreter?data="
            + encodeURIComponent(q);


  fetch(url)
  .then(r => r.json())
  .then(d => {


    let out = "";


    d.elements.forEach(x => {
      out += (x.tags.name || "Place") +
             " (" + x.tags.amenity + ")<br>";
    });


    document.getElementById("res").innerHTML = out;
  });
}


</script>


</body>
</html>

